scopeName: 'source.ximl'
name: 'XIML'
fileTypes: ['ximl']
patterns: [
  {
    name: 'comment.line.double-slash.ximl'
    match: '//.*$'
  }
  {
    name: 'comment.block.ximl'
    begin: '/\\*'
    end: '\\*/'
  }
  {
    name: 'entity.name.tag.ximl'
    match: '\\b[a-zA-Z_][a-zA-Z0-9_:]*(?=\\s*[|{])'
  }
  {
    name: 'variable.parameter.ximl'
    match: '\\b@[a-zA-Z_][a-zA-Z0-9_-]*'
  }
  {
    name: 'punctuation.definition.ximl'
    match: '[|{}]'
  }
  {
    name: 'string.quoted.double.ximl'
    begin: '"'
    end: '"'
    patterns: [
      {
        name: 'constant.character.escape.ximl'
        match: '\\\\.'
      }
    ]
  }
  {
    name: 'string.quoted.single.ximl'
    begin: "'"
    end: "'"
    patterns: [
      {
        name: 'constant.character.escape.ximl'
        match: '\\\\.'
      }
    ]
  }
]
